{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tick-stream.local/contracts/config.schema.json",
  "title": "Tick Stream Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["gm", "feishu", "watchlist", "rules", "audit"],
  "properties": {
    "gm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["token", "serv_addr", "strategy_id"],
      "properties": {
        "token": {
          "type": "string",
          "minLength": 1,
          "description": "GM token value loaded directly from the local YAML configuration."
        },
        "serv_addr": {
          "type": "string",
          "minLength": 1
        },
        "strategy_id": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": ["live"],
          "default": "live"
        }
      }
    },
    "feishu": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "app_id",
        "app_secret",
        "receive_id_type",
        "receive_id",
        "token_refresh_margin_seconds",
        "max_attempts",
        "retry_backoff_seconds"
      ],
      "properties": {
        "app_id": {
          "type": "string",
          "minLength": 1
        },
        "app_secret": {
          "type": "string",
          "minLength": 1
        },
        "receive_id_type": {
          "type": "string",
          "enum": ["chat_id", "open_id", "user_id", "union_id", "email"]
        },
        "receive_id": {
          "type": "string",
          "minLength": 1
        },
        "token_refresh_margin_seconds": {
          "type": "integer",
          "minimum": 60,
          "default": 300
        },
        "max_attempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "default": 3
        },
        "retry_backoff_seconds": {
          "type": "array",
          "items": {
            "type": "number",
            "minimum": 0
          },
          "default": [1, 5, 30]
        }
      }
    },
    "watchlist": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["symbol"],
        "properties": {
          "symbol": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string"
          },
          "market": {
            "type": "string"
          },
          "active": {
            "type": "boolean",
            "default": true
          },
          "rule_profile": {
            "type": "string",
            "default": "default"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          }
        }
      }
    },
    "rules": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "price_window_seconds",
          "price_return_threshold_pct",
          "momentum_impulse_seconds",
          "momentum_baseline_seconds",
          "momentum_z_threshold",
          "momentum_min_return_pct",
          "momentum_min_nonzero_baseline_samples",
          "momentum_zero_mad_min_return_pct",
          "momentum_notify_min_return_pct",
          "momentum_notify_volume_burst_ratio",
          "momentum_notify_orderbook_min_volume_burst_ratio",
          "momentum_notify_orderbook_imbalance_ratio",
          "momentum_notify_cancel_add_ratio",
          "alert_aggregation_window_seconds",
          "orderbook_window_seconds",
          "orderbook_min_consecutive_ticks",
          "orderbook_cancel_ratio_threshold",
          "orderbook_imbalance_ratio_threshold",
          "orderbook_standalone_min_severity",
          "orderbook_notify_min_return_pct",
          "orderbook_notify_volume_burst_ratio",
          "cooldown_seconds"
        ],
        "properties": {
          "price_window_seconds": {
            "type": "integer",
            "minimum": 1,
            "default": 30
          },
          "price_return_threshold_pct": {
            "type": "number",
            "exclusiveMinimum": 0,
            "default": 1.5
          },
          "momentum_impulse_seconds": {
            "type": "integer",
            "minimum": 1,
            "default": 10
          },
          "momentum_baseline_seconds": {
            "type": "integer",
            "minimum": 2,
            "default": 180
          },
          "momentum_z_threshold": {
            "type": "number",
            "exclusiveMinimum": 0,
            "default": 3.0
          },
          "momentum_min_return_pct": {
            "type": "number",
            "minimum": 0,
            "default": 0.3
          },
          "momentum_min_nonzero_baseline_samples": {
            "type": "integer",
            "minimum": 0,
            "default": 5
          },
          "momentum_zero_mad_min_return_pct": {
            "type": "number",
            "minimum": 0,
            "default": 0.8
          },
          "momentum_notify_min_return_pct": {
            "type": "number",
            "minimum": 0,
            "default": 0.8
          },
          "momentum_notify_volume_burst_ratio": {
            "type": "number",
            "minimum": 0,
            "default": 2.0
          },
          "momentum_notify_orderbook_min_volume_burst_ratio": {
            "type": "number",
            "minimum": 0,
            "default": 1.0
          },
          "momentum_notify_orderbook_imbalance_ratio": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "default": 0.9
          },
          "momentum_notify_cancel_add_ratio": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "default": 0.6
          },
          "alert_aggregation_window_seconds": {
            "type": "integer",
            "minimum": 0,
            "default": 30
          },
          "orderbook_window_seconds": {
            "type": "integer",
            "minimum": 1,
            "default": 30
          },
          "orderbook_min_consecutive_ticks": {
            "type": "integer",
            "minimum": 1,
            "default": 2
          },
          "orderbook_cancel_ratio_threshold": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "default": 0.35
          },
          "orderbook_imbalance_ratio_threshold": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "default": 0.7
          },
          "orderbook_standalone_min_severity": {
            "type": "string",
            "enum": ["warning", "high", "critical"],
            "default": "high"
          },
          "orderbook_notify_min_return_pct": {
            "type": "number",
            "minimum": 0,
            "default": 0.4
          },
          "orderbook_notify_volume_burst_ratio": {
            "type": "number",
            "minimum": 0,
            "default": 2.0
          },
          "min_ticks_short_window": {
            "type": "integer",
            "minimum": 2,
            "default": 3
          },
          "min_ticks_baseline_window": {
            "type": "integer",
            "minimum": 3,
            "default": 20
          },
          "cooldown_seconds": {
            "type": "integer",
            "minimum": 0,
            "default": 180
          },
          "severity_thresholds": {
            "type": "object",
            "additionalProperties": false,
            "required": ["warning", "high", "critical"],
            "properties": {
              "warning": {
                "$ref": "#/$defs/severityThreshold"
              },
              "high": {
                "$ref": "#/$defs/severityThreshold"
              },
              "critical": {
                "$ref": "#/$defs/severityThreshold"
              }
            }
          },
          "ignored_sessions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["start", "end"],
              "properties": {
                "start": {
                  "type": "string",
                  "pattern": "^\\d{2}:\\d{2}:\\d{2}$"
                },
                "end": {
                  "type": "string",
                  "pattern": "^\\d{2}:\\d{2}:\\d{2}$"
                }
              }
            },
            "default": []
          }
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dir"],
      "properties": {
        "dir": {
          "type": "string",
          "minLength": 1
        },
        "write_tick_summaries": {
          "type": "boolean",
          "default": true
        }
      }
    }
  },
  "$defs": {
    "severityThreshold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["price_return_pct", "momentum_z", "orderbook_cancel_ratio", "orderbook_imbalance_ratio"],
      "properties": {
        "price_return_pct": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "momentum_z": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "orderbook_cancel_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "orderbook_imbalance_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
